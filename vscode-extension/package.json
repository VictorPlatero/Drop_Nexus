{
  "name": "database-nexus-vscode",
  "displayName": "Database Nexus Replicator",
  "description": "Extension de VS Code para trabajar con la skill, plugin y flujo de replicacion de Database Nexus.",
  "version": "0.1.0",
  "publisher": "victorplatero",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VictorPlatero/Drop_Nexus.git",
    "directory": "vscode-extension"
  },
  "homepage": "https://github.com/VictorPlatero/Drop_Nexus/tree/main/vscode-extension",
  "bugs": {
    "url": "https://github.com/VictorPlatero/Drop_Nexus/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "database",
    "replication",
    "sql",
    "sqlite",
    "mysql",
    "postgresql",
    "railway"
  ],
  "activationEvents": [
    "onCommand:databaseNexus.openSkill",
    "onCommand:databaseNexus.openPlugin",
    "onCommand:databaseNexus.openChatbox",
    "onCommand:databaseNexus.insertPrompt",
    "onCommand:databaseNexus.validateAssistant",
    "onCommand:databaseNexus.describeDatabaseFile",
    "onCommand:databaseNexus.generateReplicationScript",
    "onCommand:databaseNexus.openLocalApp"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "databaseNexus.openSkill",
        "title": "Database Nexus: Abrir skill del asistente"
      },
      {
        "command": "databaseNexus.openPlugin",
        "title": "Database Nexus: Abrir plugin del asistente"
      },
      {
        "command": "databaseNexus.openChatbox",
        "title": "Database Nexus: Abrir chatbox integrado"
      },
      {
        "command": "databaseNexus.insertPrompt",
        "title": "Database Nexus: Insertar consulta sugerida"
      },
      {
        "command": "databaseNexus.validateAssistant",
        "title": "Database Nexus: Validar skill, plugin y chatbox"
      },
      {
        "command": "databaseNexus.describeDatabaseFile",
        "title": "Database Nexus: Describir archivo de base de datos"
      },
      {
        "command": "databaseNexus.generateReplicationScript",
        "title": "Database Nexus: Generar script de replicacion"
      },
      {
        "command": "databaseNexus.openLocalApp",
        "title": "Database Nexus: Abrir app local"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "databaseNexus.describeDatabaseFile",
          "when": "resourceExtname == .sql || resourceExtname == .sqlite || resourceExtname == .sqlite3 || resourceExtname == .db || resourceExtname == .json || resourceExtname == .ndjson || resourceExtname == .csv",
          "group": "navigation@10"
        },
        {
          "command": "databaseNexus.generateReplicationScript",
          "group": "navigation@15"
        },
        {
          "command": "databaseNexus.validateAssistant",
          "group": "navigation@20"
        }
      ],
      "commandPalette": [
        {
          "command": "databaseNexus.openSkill"
        },
        {
          "command": "databaseNexus.openPlugin"
        },
        {
          "command": "databaseNexus.openChatbox"
        },
        {
          "command": "databaseNexus.insertPrompt"
        },
        {
          "command": "databaseNexus.validateAssistant"
        },
        {
          "command": "databaseNexus.describeDatabaseFile"
        },
        {
          "command": "databaseNexus.generateReplicationScript"
        },
        {
          "command": "databaseNexus.openLocalApp"
        }
      ]
    }
  }
}
